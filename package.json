{
  "name": "pj-jurisprudencia-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Scraper HTTP para el corpus público de jurisprudencia del PJ del Perú",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "scrape": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:phase0": "node scripts/validate-phase0-fixtures.mjs",
    "reconcile:corpus": "node scripts/finalize-corpus-reconciliation.mjs",
    "check": "npm run format:check && npm run lint && npm run validate:phase0 && npm run test && npm run build"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.10.0",
    "fast-xml-validator": "^1.2.0",
    "pino": "^10.3.1",
    "tough-cookie": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "nock": "^14.0.16",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.7"
  }
}
